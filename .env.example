# Copier ce fichier en ".env" et ajuster les valeurs.
# Toute valeur absente ici prend le defaut defini en haut de crous_watch.py.

# ID de la phase en cours (le nombre a la fin de /api/fr/search/XX).
# Liste des phases avec noms et dates (plus simple que DevTools) :
#   https://trouverunlogement.lescrous.fr/api/fr/tools
# Au 12/07/2026 : 47 = "Phase complementaire 2026-2027", 42 = "Fil de l'Eau 2025-26".
SEARCH_ID=47

# Topic ntfy.sh : choisis un nom unique et difficile a deviner,
# puis abonne-toi a ce topic dans l'application ntfy sur ton telephone.
NTFY_TOPIC=crous-rouen-CHANGE-MOI

# Intervalle entre deux verifications, en secondes (300 = 5 minutes).
INTERVALLE_SECONDES=300

# Bounding box autour de Rouen (coin Nord-Ouest / coin Sud-Est).
# Pour la recuperer : cadre la carte du site comme tu veux, puis regarde
# le champ "location" du payload dans DevTools.
BBOX_LON_OUEST=0.95
BBOX_LAT_NORD=49.54
BBOX_LON_EST=1.25
BBOX_LAT_SUD=49.34
